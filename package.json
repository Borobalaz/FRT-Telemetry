{
  "name": "frt-telemetry",
  "version": "1.0.1",
  "description": "Desktop telemetry visualization for FRT",
  "author": "Böröczky Balázs",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dist": "electron-builder --publish always",
    "release": "npm run build && node release.cjs"
  },
  "build": {
    "appId": "com.frt.telemetry",
    "productName": "FRT Telemetry",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Borobalaz",
        "repo": "FRT-Telemetry"
      }
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@passoa/dbcparser": "^1.0.7",
    "buffer": "^6.0.3",
    "candied": "^2.2.0",
    "preact": "^10.26.9",
    "react-google-charts": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@preact/preset-vite": "^2.10.2",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "vite-plugin-electron": "^0.29.0"
  }
}