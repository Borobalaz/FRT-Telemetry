{
  "name": "frt-telemetry",
  "version": "1.0.1",
  "description": "Desktop telemetry visualization for FRT",
  "author": "Böröczky Balázs",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:renderer": "vite build --watch",
    "dev:electron:main": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=dist-electron/main.js --external:electron --watch",
    "dev:electron:preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron --watch",
    "dev:electron": "concurrently -k \"npm:dev:electron:main\" \"npm:dev:electron:preload\"",
    "dev:desktop": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"wait-on file:dist/index.html file:dist-electron/main.js file:dist-electron/preload.cjs && electron .\"",
    "build": "npm run build:desktop",
    "build:renderer": "vite build",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=dist-electron/main.js --external:electron && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist-electron/preload.cjs --external:electron",
    "build:desktop": "npm run build:renderer && npm run build:electron && electron-builder",
    "release": "node scripts/publish-github.mjs"
  },
  "build": {
    "appId": "com.frt.telemetry",
    "productName": "FRT Telemetry",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Borobalaz",
        "repo": "FRT-Telemetry"
      }
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@passoa/dbcparser": "^1.0.7",
    "buffer": "^6.0.3",
    "candied": "^2.2.0",
    "preact": "^10.26.9",
    "react-google-charts": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.4.0",
    "@preact/preset-vite": "^2.10.2",
    "concurrently": "^9.2.1",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.10",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.5"
  }
}
